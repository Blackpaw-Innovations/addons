<odoo>
 
 <!-- Staff Tracking Views -->
<record id="view_staff_tracking_form" model="ir.ui.view">
  <field name="name">migration.staff.tracking.form</field>
  <field name="model">migration.staff.tracking</field>
  <field name="arch" type="xml">
    <form>
      <sheet>
        <group>
          <field name="name"/>
          <field name="color"/>
        </group>
      </sheet>
    </form>
  </field>
</record>

<record id="view_staff_tracking_tree" model="ir.ui.view">
  <field name="name">migration.staff.tracking.tree</field>
  <field name="model">migration.staff.tracking</field>
  <field name="arch" type="xml">
    <tree>
      <field name="name"/>
      <field name="color"/>
    </tree>
  </field>
</record>

<record id="action_staff_tracking" model="ir.actions.act_window">
  <field name="name">Staff Tracking</field>
  <field name="res_model">migration.staff.tracking</field>
  <field name="view_mode">tree,form</field>
</record>

<menuitem id="menu_staff_tracking" name="Staff Tracking"
          parent="menu_crm_migration_root" action="action_staff_tracking" sequence="10"/>


