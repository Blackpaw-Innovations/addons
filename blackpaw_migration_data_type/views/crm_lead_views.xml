<odoo>
  <record id="view_crm_lead_form_inherit_migration_data" model="ir.ui.view">
    <field name="name">crm.lead.form.inherit.migration.data</field>
    <field name="model">crm.lead</field>
    <field name="inherit_id" ref="crm.crm_lead_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='tag_ids']" position="after">
        <field name="migration_data_type_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
      </xpath>
    </field>
  </record>
</odoo>
