<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_appraisal_template_tree" model="ir.ui.view">
        <field name="name">bp.appraisal.template.tree</field>
        <field name="model">bp.appraisal.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_appraisal_template_form" model="ir.ui.view">
        <field name="name">bp.appraisal.template.form</field>
        <field name="model">bp.appraisal.template</field>
        <field name="arch" type="xml">
            <form string="Appraisal Template">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="reviewer_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Internal description"/>
                    </group>
                    <notebook>
                        <page string="Questions">
                            <field name="question_ids">
                                <tree editable="bottom">
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="question_type"/>
                                    <field name="weight"/>
                                    <field name="help_text"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_appraisal_template" model="ir.actions.act_window">
        <field name="name">Appraisal Templates</field>
        <field name="res_model">bp.appraisal.template</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'default_company_id': company_id}</field>
    </record>

    <menuitem id="menu_bp_appraisal_root" name="Blackpaw Appraisal" parent="hr.menu_hr_root" sequence="40"/>
    <menuitem id="menu_bp_appraisal_config" name="Configuration" parent="menu_bp_appraisal_root" sequence="10"/>
    <menuitem id="menu_bp_appraisal_templates" name="Appraisal Templates" parent="menu_bp_appraisal_config" action="action_appraisal_template" sequence="10"/>
</odoo>
