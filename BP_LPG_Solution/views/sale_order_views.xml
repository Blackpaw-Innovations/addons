<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_lpg" model="ir.ui.view">
        <field name="name">sale.order.form.lpg</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="LPG">
                    <group>
                        <field name="lpg_exchange_required" readonly="1" />
                        <field name="lpg_exchange_required_qty" readonly="1" />
                        <field name="lpg_exchange_returned_qty" readonly="1" />
                        <field name="lpg_exchange_missing_qty" readonly="1" />
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='product_id']" position="after">
                <field name="lpg_exchange_line" readonly="1" />
                <field name="returned_cylinder_lot_id" />
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="after">
                <field name="lpg_exchange_line" readonly="1" />
                <field name="returned_cylinder_lot_id" />
            </xpath>
        </field>
    </record>
</odoo>
