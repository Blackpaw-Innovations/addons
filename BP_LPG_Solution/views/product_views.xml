<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_lpg" model="ir.ui.view">
        <field name="name">product.template.form.lpg</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="LPG">
                    <group>
                        <field name="is_lpg_cylinder" />
                        <field name="is_lpg_gas" />
                        <field name="cylinder_capacity_kg" />
                        <field name="requires_exchange" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
