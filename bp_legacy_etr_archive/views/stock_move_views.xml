<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_form_bp_legacy_etr_archive" model="ir.ui.view">
        <field name="name">stock.move.form.bp.legacy.etr.archive</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="bp_legacy_etr_archive_present" invisible="1"/>
            </xpath>
            <xpath expr="//sheet/group" position="after">
                <group string="Legacy ETR Archive"
                       groups="stock.group_stock_manager,base.group_system"
                       invisible="not bp_legacy_etr_archive_present">
                    <group string="Legacy Values">
                        <field name="bp_legacy_oscu_sar_number" readonly="1"/>
                        <field name="bp_legacy_oscu_flow_type_code" readonly="1"/>
                    </group>
                    <group string="Archive Provenance">
                        <field name="bp_legacy_source_dump" readonly="1"/>
                        <field name="bp_legacy_source_record_id" readonly="1"/>
                        <field name="bp_legacy_archive_match_method" readonly="1"/>
                        <field name="bp_legacy_archive_imported_at" readonly="1"/>
                        <field name="bp_legacy_archive_imported_by" readonly="1"/>
                        <field name="bp_legacy_archive_note" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_move_search_bp_legacy_etr_archive" model="ir.ui.view">
        <field name="name">stock.move.search.bp.legacy.etr.archive</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group" position="before">
                <separator/>
                <filter name="bp_legacy_etr_archive"
                        string="Legacy ETR"
                        domain="[('bp_legacy_etr_archive_present', '=', True)]"
                        groups="stock.group_stock_manager,base.group_system"/>
            </xpath>
        </field>
    </record>
</odoo>
