<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_draft" model="hr.payslip.stage">
            <field name="name">Draft</field>
            <field name="sequence">10</field>
            <field name="state">draft</field>
        </record>

        <record id="stage_verify" model="hr.payslip.stage">
            <field name="name">HR Review</field>
            <field name="sequence">20</field>
            <field name="state">verify</field>
        </record>

        <record id="stage_approval" model="hr.payslip.stage">
            <field name="name">Approval</field>
            <field name="sequence">30</field>
            <field name="state">approval</field>
        </record>

        <record id="stage_ready" model="hr.payslip.stage">
            <field name="name">Ready for Payment</field>
            <field name="sequence">50</field>
            <field name="state">payment_ready</field>
        </record>

        <record id="stage_paid" model="hr.payslip.stage">
            <field name="name">Paid</field>
            <field name="sequence">60</field>
            <field name="state">done</field>
        </record>

        <record id="stage_cancel" model="hr.payslip.stage">
            <field name="name">Rejected</field>
            <field name="sequence">70</field>
            <field name="state">cancel</field>
        </record>
    </data>
</odoo>
