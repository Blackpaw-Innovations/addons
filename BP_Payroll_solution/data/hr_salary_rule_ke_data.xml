        <field name="python_code"><![CDATA[
config = payslip._bp_ke_get_config()
insurance = results.get('INSURANCE', inputs.get('INSURANCE', 0.0))
# fallback to contract monthly insurance premium
if not insurance:
    insurance = contract and contract.insurance_premium or 0.0
insurance = abs(insurance or 0.0)
# Relief is 15% of insurance premium (no cap)
result = insurance * 0.15
]]></field>
