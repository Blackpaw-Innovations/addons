<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Payment Wizard -->
    <record id="view_bp_payroll_payment_wizard_form" model="ir.ui.view">
        <field name="name">bp.payroll.payment.wizard.form</field>
        <field name="model">bp.payroll.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Register Payment">
                <group>
                    <group>
                        <field name="journal_id" widget="selection"/>
                        <field name="payment_date"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="run_id" invisible="not run_id" readonly="1"/>
                    </group>
                </group>
                <field name="payslip_ids" nolabel="1" options="{'no_create': True}">
                    <tree create="0" delete="1">
                        <field name="employee_id"/>
                        <field name="total_net" sum="Total"/>
                        <field name="state" invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_confirm_payment" string="Confirm Payment" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Batch Generation Wizard -->
    <record id="view_bp_payroll_batch_wizard_form" model="ir.ui.view">
        <field name="name">bp.payroll.batch.wizard.form</field>
        <field name="model">bp.payroll.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Payslips">
                <group>
                    <field name="mode" widget="radio"/>
                    <field name="department_id" invisible="mode != 'dept'" required="mode == 'dept'"/>
                    <field name="employee_ids" widget="many2many_tags" invisible="mode != 'selected'" required="mode == 'selected'"/>
                    <field name="run_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
