<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_bp_payroll">
        <field name="name">Payroll</field>
        <field name="description">Manage Payroll.</field>
        <field name="sequence">20</field>
        <field name="visible" eval="1"/>
    </record>

    <!-- Roles -->
    <record id="group_bp_payroll_officer" model="res.groups">
        <field name="name">Payroll Officer</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bp_payroll_manager" model="res.groups">
        <field name="name">Payroll Manager</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('group_bp_payroll_officer'))]"/>
    </record>

    <record id="group_bp_payroll_accountant" model="res.groups">
        <field name="name">Payroll Accountant</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice')), (4, ref('group_bp_payroll_officer'))]"/>
    </record>

    <record id="group_bp_payroll_director" model="res.groups">
        <field name="name">Payroll Director</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('group_bp_payroll_manager'))]"/>
    </record>

    <record id="group_bp_payroll_hr_officer" model="res.groups">
        <field name="name">Payroll HR Officer (limited salary visibility)</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_bp_payroll_employee" model="res.groups">
        <field name="name">Payroll Employee Self-Service</field>
        <field name="category_id" ref="module_category_bp_payroll"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Record rules -->
    <record id="bp_rule_payslip_employee_self" model="ir.rule">
        <field name="name">Payslip - employee own</field>
        <field name="model_id" ref="model_hr_payslip"/>
        <field name="groups" eval="[(4, ref('group_bp_payroll_employee'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_unlink" eval="0"/>
        <field name="perm_create" eval="0"/>
    </record>

    <record id="bp_rule_payslip_run_company" model="ir.rule">
        <field name="name">Payroll batch - company</field>
        <field name="model_id" ref="model_hr_payslip_run"/>
        <field name="groups" eval="[(4, ref('group_bp_payroll_officer')), (4, ref('group_bp_payroll_manager')), (4, ref('group_bp_payroll_accountant'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', user.company_ids.ids)]</field>
    </record>

    <record id="bp_rule_payslip_company" model="ir.rule">
        <field name="name">Payslip - company</field>
        <field name="model_id" ref="model_hr_payslip"/>
        <field name="groups" eval="[(4, ref('group_bp_payroll_officer')), (4, ref('group_bp_payroll_manager')), (4, ref('group_bp_payroll_accountant'))]"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', user.company_ids.ids)]</field>
    </record>
</odoo>
