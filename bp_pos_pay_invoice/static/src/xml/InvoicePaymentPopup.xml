<templates id="template" xml:space="preserve">
    <t t-name="bp_pos_pay_invoice.InvoicePaymentButton" owl="1">
        <button class="control-button btn btn-light rounded-0 fw-bolder" t-if="shouldShow" t-on-click="onClick">
            <i class="fa fa-money-bill me-1"/>
            <span>Pay Invoice</span>
        </button>
    </t>

    <t t-name="bp_pos_pay_invoice.InvoicePaymentPopup" owl="1">
        <div class="popup invoice-payment-popup" style="max-width: 800px;">
            <header class="modal-header" style="border-bottom: 1px solid #e0e0e0; padding: 20px 32px; background: #fff;">
                <h4 class="modal-title" style="font-size: 22px; font-weight: 600; color: #1a1a1a; margin: 0;">Pay Invoice</h4>
            </header>
            
            <main class="modal-body" style="max-height: 75vh; overflow-y: auto; padding: 32px; background: #fafafa;">
                <t t-if="state.loading">
                    <div class="text-center">Loading invoices...</div>
                </t>
                <t t-elif="!state.invoices.length">
                    <div class="text-center">No open invoices for this customer.</div>
                </t>
                <t t-else="">
                    <table class="table table-sm o_list_table" style="background: #fff;">
                        <thead>
                            <tr>
                                <th>Invoice</th>
                                <th>Date</th>
                                <th class="text-end">Residual</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.invoices" t-as="inv" t-key="inv.id">
                                <tr t-att-class="{'o_selected_row': state.selectedInvoiceId === inv.id}" t-on-click="() => this.selectInvoice(inv)">
                                    <td>
                                        <input type="radio" name="invoice_select" t-att-checked="state.selectedInvoiceId === inv.id"/>
                                        <t t-esc="inv.name or inv.id"/>
                                    </td>
                                    <td><t t-esc="inv.invoice_date"/></td>
                                    <td class="text-end">
                                        <t t-esc="inv.amount_residual"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <div class="mt-2">
                        <label class="form-label">Payment Amount</label>
                        <input type="number" min="0" step="0.01" class="form-control" t-att-readonly="allowPartialPayments ? null : 'readonly'" t-att-value="state.paymentAmount" t-on-input="onAmountChange"/>
                    </div>
                </t>
            </main>
            
            <footer class="modal-footer" style="display: flex; justify-content: flex-end; gap: 12px; padding: 16px 32px; background: #fafafa; border-top: 1px solid #e0e0e0;">
                <button class="btn btn-light" t-on-click="cancel" style="padding: 10px 20px;">
                    Cancel
                </button>
                <button class="btn btn-primary" t-on-click="confirm" style="padding: 10px 20px;">
                    Confirm
                </button>
            </footer>
        </div>
    </t>
</templates>
