<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_mwanzo_bank_fee_wizard_form" model="ir.ui.view">
        <field name="name">mwanzo.bank.fee.wizard.form</field>
        <field name="model">mwanzo.bank.fee.wizard</field>
        <field name="arch" type="xml">
            <form string="Record Bank Fee">
                <group>
                    <group>
                        <field name="journal_id"/>
                        <field name="amount"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="date"/>
                        <field name="name"/>
                        <field name="account_id"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                </group>
                <footer>
                    <button string="Post Fee" type="object" name="action_post_fee" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mwanzo_bank_fee_wizard" model="ir.actions.act_window">
        <field name="name">Record Bank Fee</field>
        <field name="res_model">mwanzo.bank.fee.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <menuitem
        id="menu_mwanzo_bank_fee_wizard"
        name="Record Bank Fee"
        parent="bp_mwanzo_marketplace.menu_mwanzo_marketplace_accounting"
        action="action_mwanzo_bank_fee_wizard"
        sequence="50"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />
</odoo>
