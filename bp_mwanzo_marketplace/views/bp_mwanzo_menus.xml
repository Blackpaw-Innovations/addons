    <record id="action_mwanzo_license_cron" model="ir.actions.act_window">
        <field name="name">Scheduler: Recurring Invoices</field>
        <field name="res_model">ir.cron</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="bp_mwanzo_marketplace.ir_cron_mwanzo_license_recurring_invoice"/>
    </record>

    <menuitem
        id="menu_mwanzo_license_cron"
        name="Scheduler: Recurring Invoices"
        parent="bp_mwanzo_marketplace.menu_mwanzo_config_automation"
        action="action_mwanzo_license_cron"
        sequence="10"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />

    <record id="action_mwanzo_stock_intake_cron" model="ir.actions.act_window">
        <field name="name">Scheduler: Auto-Intake</field>
        <field name="res_model">ir.cron</field>
        <field name="view_mode">form</field>
