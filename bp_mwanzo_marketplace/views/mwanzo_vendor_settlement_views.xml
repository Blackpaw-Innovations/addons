<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Settlement Run -->
    <record id="view_mwanzo_settlement_run_kanban" model="ir.ui.view">
        <field name="name">mwanzo.settlement.run.kanban</field>
        <field name="model">mwanzo.settlement.run</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" quick_create="false">
                <field name="stage_id"/>
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card d-flex flex-column p-2">
                            <div class="o_kanban_card_header mb-2">
                                <div class="o_kanban_card_header_title">
                                    <div class="h5 mb-0 text-primary fw-bold">
                                        <field name="name"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_card_content flex-grow-1">
                                <div class="d-flex align-items-center mb-2 text-muted small">
                                    <i class="fa fa-calendar me-2" title="Duration"/>
                                    <span>
                                        <field name="date_start"/> 
                                        <i class="fa fa-long-arrow-right mx-1" title="to"/> 
                                        <field name="date_end"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_mwanzo_settlement_run_tree" model="ir.ui.view">
        <field name="name">mwanzo.settlement.run.tree</field>
        <field name="model">mwanzo.settlement.run</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="stage_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <record id="view_mwanzo_settlement_run_form" model="ir.ui.view">
        <field name="name">mwanzo.settlement.run.form</field>
        <field name="model">mwanzo.settlement.run</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_wizard" string="Generate Statements" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Set to Draft" type="object" class="btn-secondary" invisible="state != 'closed'"/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. December 2025"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="state" invisible="1"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statements">
                            <field name="statement_ids" readonly="1">
                                <tree>
                                    <field name="vendor_id"/>
                                    <field name="total_sales"/>
                                    <field name="total_commission"/>
                                    <field name="total_net_payable"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_mwanzo_settlement_run" model="ir.actions.act_window">
        <field name="name">Settlement Runs</field>
        <field name="res_model">mwanzo.settlement.run</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="groups_id" eval="[(4, ref('bp_mwanzo_marketplace.group_mwanzo_manager'))]"/>
    </record>

    <!-- Settlement Run Stages -->
    <record id="view_mwanzo_settlement_run_stage_tree" model="ir.ui.view">
        <field name="name">mwanzo.settlement.run.stage.tree</field>
        <field name="model">mwanzo.settlement.run.stage</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="target_state"/>
                <field name="fold"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_mwanzo_settlement_run_stage_form" model="ir.ui.view">
        <field name="name">mwanzo.settlement.run.stage.form</field>
        <field name="model">mwanzo.settlement.run.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="target_state"/>
                            <field name="fold"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mwanzo_settlement_run_stage" model="ir.actions.act_window">
        <field name="name">Settlement Run Stages</field>
        <field name="res_model">mwanzo.settlement.run.stage</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('bp_mwanzo_marketplace.group_mwanzo_manager'))]"/>
    </record>

    <menuitem
        id="menu_mwanzo_settlement_run_stage"
        name="Settlement Run Stages"
        parent="bp_mwanzo_marketplace.menu_mwanzo_config_stages"
        action="action_mwanzo_settlement_run_stage"
        sequence="60"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />

    <!-- Settlement Wizard -->
    <record id="view_mwanzo_vendor_settlement_wizard" model="ir.ui.view">
        <field name="name">mwanzo.vendor.settlement.wizard.form</field>
        <field name="model">mwanzo.vendor.settlement.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Vendor Statements">
                <div class="text-muted mb-3">
                    <p>Select the period and optional filters to generate vendor statements.</p>
                </div>
                <group>
                    <group string="Period">
                        <field name="date_from" readonly="settlement_run_id"/>
                        <field name="date_to" readonly="settlement_run_id"/>
                        <field name="settlement_run_id" invisible="1"/>
                    </group>
                    <group string="Filters">
                        <field name="vendor_id" options="{'no_create': True}"/>
                        <field name="theme_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </group>
                <footer>
                    <button string="Generate Statements" type="object" name="action_generate_statements" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" special="cancel" class="btn-secondary" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mwanzo_vendor_settlement_wizard" model="ir.actions.act_window">
        <field name="name">Vendor Settlement Wizard</field>
        <field name="res_model">mwanzo.vendor.settlement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('bp_mwanzo_marketplace.group_mwanzo_manager'))]"/>
    </record>

    <!-- Vendor Statement Stages -->
    <record id="view_mwanzo_vendor_statement_stage_tree" model="ir.ui.view">
        <field name="name">mwanzo.vendor.statement.stage.tree</field>
        <field name="model">mwanzo.vendor.statement.stage</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="target_state"/>
                <field name="fold"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_mwanzo_vendor_statement_stage" model="ir.actions.act_window">
        <field name="name">Vendor Statement Stages</field>
        <field name="res_model">mwanzo.vendor.statement.stage</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_mwanzo_vendor_statement_stage"
        name="Vendor Statement Stages"
        parent="bp_mwanzo_marketplace.menu_mwanzo_config_stages"
        action="action_mwanzo_vendor_statement_stage"
        sequence="70"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />

    <!-- Vendor Statements -->
    <record id="view_mwanzo_vendor_statement_tree" model="ir.ui.view">
        <field name="name">mwanzo.vendor.statement.tree</field>
        <field name="model">mwanzo.vendor.statement</field>
        <field name="arch" type="xml">
            <tree create="false">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="total_sales"/>
                <field name="total_commission"/>
                <field name="total_net_payable"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_mwanzo_vendor_statement_form" model="ir.ui.view">
        <field name="name">mwanzo.vendor.statement.form</field>
        <field name="model">mwanzo.vendor.statement</field>
        <field name="arch" type="xml">
            <form string="Vendor Statement" create="false">
                <header>
                    <button name="%(bp_mwanzo_marketplace.action_mwanzo_vendor_settlement_wizard)d" 
                            string="Generate via Wizard" 
                            type="action" 
                            class="btn-primary" 
                            invisible="id"/>
                    <button name="action_confirm" type="object" string="Confirm" invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_create_vendor_bill" type="object" string="Create Vendor Bill" invisible="state != 'confirmed'" class="btn-secondary"/>
                    <field name="stage_id" invisible="1"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,invoiced,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="vendor_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="vendor_bill_id" context="{'default_move_type': 'in_invoice'}"/>
                        </group>
                    </group>
                    <group>
                        <field name="total_sales" readonly="1"/>
                        <field name="total_commission" readonly="1"/>
                        <field name="total_net_payable" readonly="1"/>
                    </group>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="pos_order_line_id"/>
                            <field name="product_id"/>
                            <field name="theme_id"/>
                            <field name="commission_percentage"/>
                            <field name="sale_amount"/>
                            <field name="commission_amount"/>
                            <field name="net_amount"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mwanzo_vendor_statement_search" model="ir.ui.view">
        <field name="name">mwanzo.vendor.statement.search</field>
        <field name="model">mwanzo.vendor.statement</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Invoiced" name="invoiced" domain="[('state', '=', 'invoiced')]"/>
            </search>
        </field>
    </record>

    <record id="action_mwanzo_vendor_statement" model="ir.actions.act_window">
        <field name="name">Vendor Statements</field>
        <field name="res_model">mwanzo.vendor.statement</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mwanzo_vendor_statement_search"/>
        <field name="groups_id" eval="[(4, ref('bp_mwanzo_marketplace.group_mwanzo_manager'))]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Vendor Statements Found
            </p>
            <p>
                Use the <a type="action" name="%(bp_mwanzo_marketplace.action_mwanzo_vendor_settlement_wizard)d">Generate Statement</a> wizard to create new statements.
            </p>
        </field>
    </record>

    <record id="action_server_generate_vendor_statements" model="ir.actions.server">
        <field name="name">Generate Statements</field>
        <field name="model_id" ref="model_mwanzo_vendor_statement"/>
        <field name="binding_model_id" ref="model_mwanzo_vendor_statement"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = env.ref('bp_mwanzo_marketplace.action_mwanzo_vendor_settlement_wizard').read()[0]
        </field>
    </record>

    <menuitem
        id="menu_mwanzo_vendor_statement"
        name="Vendor Settlements"
        parent="bp_mwanzo_marketplace.menu_mwanzo_marketplace_accounting"
        action="bp_mwanzo_marketplace.action_mwanzo_vendor_statement"
        sequence="30"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />

    <menuitem
        id="menu_mwanzo_settlement_run"
        name="Settlement Runs"
        parent="bp_mwanzo_marketplace.menu_mwanzo_marketplace_accounting"
        action="action_mwanzo_settlement_run"
        sequence="20"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />

    <menuitem
        id="menu_mwanzo_vendor_settlement_wizard"
        name="Run Settlement"
        parent="bp_mwanzo_marketplace.menu_mwanzo_marketplace_accounting"
        action="bp_mwanzo_marketplace.action_mwanzo_vendor_settlement_wizard"
        sequence="25"
        groups="bp_mwanzo_marketplace.group_mwanzo_manager"
    />
</odoo>
