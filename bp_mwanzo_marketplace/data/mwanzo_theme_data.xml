<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Theme Stages -->
        <record id="theme_stage_new" model="mwanzo.theme.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="target_state">draft</field>
        </record>

        <record id="theme_stage_planning" model="mwanzo.theme.stage">
            <field name="name">Planning</field>
            <field name="sequence">20</field>
            <field name="target_state">draft</field>
        </record>

        <record id="theme_stage_active" model="mwanzo.theme.stage">
            <field name="name">Active</field>
            <field name="sequence">30</field>
            <field name="target_state">active</field>
        </record>

        <record id="theme_stage_closed" model="mwanzo.theme.stage">
            <field name="name">Closed</field>
            <field name="sequence">40</field>
            <field name="target_state">closed</field>
            <field name="fold" eval="True"/>
        </record>
    </data>
</odoo>
