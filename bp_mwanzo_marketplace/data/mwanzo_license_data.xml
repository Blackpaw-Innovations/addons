<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="stage_draft" model="mwanzo.license.stage">
            <field name="name">Draft</field>
            <field name="sequence">10</field>
            <field name="target_state">draft</field>
        </record>
        <record id="stage_active" model="mwanzo.license.stage">
            <field name="name">Active</field>
            <field name="sequence">20</field>
            <field name="target_state">active</field>
        </record>
        <record id="stage_expired" model="mwanzo.license.stage">
            <field name="name">Expired</field>
            <field name="sequence">30</field>
            <field name="fold">True</field>
            <field name="target_state">expired</field>
        </record>
        <record id="stage_cancelled" model="mwanzo.license.stage">
            <field name="name">Cancelled</field>
            <field name="sequence">40</field>
            <field name="fold">True</field>
            <field name="target_state">cancelled</field>
        </record>
    </data>
</odoo>
