<odoo>
    <record id="view_crm_opportunity_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.project.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Create Project button only visible in won stage and if no project exists -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_create_project"
                    type="object"
                    class="oe_highlight"
                    icon="fa-tasks"
                    string="Create Project"
                    invisible="project_id != False or probability != 100"/>
            </xpath>
            <!-- Project smart button in button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="open_project"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-external-link"
                    string="Project"
                    invisible="project_id == False">
                    <field name="project_id" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>    
</odoo>