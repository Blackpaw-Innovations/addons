<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="bp_role_dashboards.SalesDashboard">
    <div class="bprd_wrap o_action">

        <div class="bprd_topbar">
            <span class="bprd_topbar_title">Sales &amp; CRM</span>
            <span class="bprd_topbar_role">Intelligence Dashboard</span>
            <span class="bprd_topbar_badge" style="background:#c62828;">RESTRICTED</span>
            <div class="bprd_topbar_sep">|</div>
            <button class="bprd_btn_refresh" t-on-click="load" t-att-disabled="state.isLoading || undefined">
                <i t-att-class="state.isLoading ? 'fa fa-spinner fa-spin' : 'fa fa-refresh'"/>
                Refresh
            </button>
            <span class="bprd_topbar_time" t-esc="now"/>
        </div>

        <div class="bprd_body">
            <t t-if="state.isLoading">
                <div class="bprd_loading">
                    <i class="fa fa-circle-o-notch fa-spin fa-2x"/>
                    <span>Loading Sales Dashboard…</span>
                </div>
            </t>

            <t t-elif="state.data">
                <div class="bprd_dash">

                    <div class="bprd_page_header">
                        <div>
                            <div class="bprd_page_title">Sales &amp; CRM</div>
                            <div class="bprd_page_sub">Revenue Intelligence Report — Restricted</div>
                        </div>
                        <div class="bprd_page_period">
                            <t t-esc="state.data.period"/>
                            <span>Refreshed <t t-esc="now"/></span>
                        </div>
                    </div>

                    <!-- KPI strip -->
                    <div class="bprd_kpi_strip">
                        <t t-foreach="state.data.kpis" t-as="kpi" t-key="kpi.label">
                            <div t-att-class="'bprd_kpi_card v-' + kpi.variant">
                                <div class="bprd_kpi_label" t-esc="kpi.label"/>
                                <div class="bprd_kpi_value" t-esc="kpi.value"/>
                                <div class="bprd_kpi_sub" t-esc="kpi.sub"/>
                            </div>
                        </t>
                    </div>

                    <!-- Pipeline funnel + Win rate trend -->
                    <div class="bprd_sec">Pipeline &amp; Win Rate</div>
                    <div class="bprd_col2">

                        <!-- Funnel -->
                        <div class="bprd_panel">
                            <div class="bprd_panel_title">Pipeline by Stage</div>
                            <t t-if="state.data.tables.funnel.length">
                                <t t-set="max_fv" t-value="maxVal(state.data.tables.funnel, 'value')"/>
                                <t t-foreach="state.data.tables.funnel" t-as="row" t-key="row.stage">
                                    <div class="bprd_funnel_row">
                                        <span class="bprd_funnel_label" t-esc="row.stage"/>
                                        <span class="bprd_funnel_count" t-esc="row.count"/>
                                        <div class="bprd_funnel_bar">
                                            <div class="bprd_bar_wrap">
                                                <div class="bprd_bar_fill" t-att-style="'width:' + Math.round(row.value / max_fv * 100) + '%'"/>
                                            </div>
                                        </div>
                                        <span class="bprd_funnel_value" t-esc="fmt(row.value)"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="bprd_empty">No active pipeline</div>
                            </t>
                        </div>

                        <!-- Win rate trend -->
                        <div class="bprd_panel">
                            <div class="bprd_panel_title">Win Rate — 4 Month Trend</div>
                            <t t-if="state.data.tables.wr_trend.length">
                                <table class="bprd_table">
                                    <thead><tr>
                                        <th>Month</th>
                                        <th class="tr">Won</th>
                                        <th class="tr">Lost</th>
                                        <th class="tr">Win Rate</th>
                                    </tr></thead>
                                    <tbody>
                                        <t t-foreach="state.data.tables.wr_trend" t-as="row" t-key="row.label">
                                            <tr>
                                                <td t-esc="row.label"/>
                                                <td class="tr bold" t-esc="row.won"/>
                                                <td class="tr muted" t-esc="row.lost"/>
                                                <td t-att-class="'tr bold ' + (row.win_rate >= 40 ? '' : (row.win_rate >= 25 ? '' : 'bold'))"
                                                    t-esc="row.win_rate + '%'"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="bprd_empty">No closed deals in period</div>
                            </t>
                        </div>
                    </div>

                    <!-- Rep performance + Loss reasons -->
                    <div class="bprd_sec">Sales Rep Performance &amp; Loss Analysis</div>
                    <div class="bprd_col2">

                        <!-- Rep performance -->
                        <div class="bprd_panel">
                            <div class="bprd_panel_title">Rep Leaderboard — MTD</div>
                            <t t-if="state.data.tables.reps.length">
                                <table class="bprd_table">
                                    <thead><tr>
                                        <th>Sales Rep</th>
                                        <th class="tr">Deals Won</th>
                                        <th class="tr">Revenue Won</th>
                                        <th class="tr">Pipeline</th>
                                    </tr></thead>
                                    <tbody>
                                        <t t-foreach="state.data.tables.reps" t-as="rep" t-key="rep.name">
                                            <tr>
                                                <td class="bold" t-esc="rep.name"/>
                                                <td class="tr" t-esc="rep.deals_won"/>
                                                <td class="tr bold" t-esc="fmt(rep.revenue_won)"/>
                                                <td class="tr muted" t-esc="fmt(rep.pipeline)"/>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <div class="bprd_empty">No rep data available</div>
                            </t>
                        </div>

                        <!-- Loss reasons -->
                        <div class="bprd_panel">
                            <div class="bprd_panel_title">Loss Reasons — 90 Days</div>
                            <t t-if="state.data.tables.loss_reasons.length">
                                <t t-set="max_lr" t-value="maxVal(state.data.tables.loss_reasons, 'count')"/>
                                <t t-foreach="state.data.tables.loss_reasons" t-as="row" t-key="row.reason">
                                    <div style="margin-bottom:10px;">
                                        <div style="display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px;">
                                            <span style="font-weight:600;" t-esc="row.reason"/>
                                            <span t-esc="row.count + ' deals'"/>
                                        </div>
                                        <div class="bprd_bar_wrap">
                                            <div class="bprd_bar_fill" t-att-style="'width:' + Math.round(row.count / max_lr * 100) + '%'"/>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="bprd_empty">No lost deals with reasons in period</div>
                            </t>
                        </div>
                    </div>

                    <!-- Stale proposals -->
                    <t t-if="state.data.tables.stale_proposals.length">
                        <div class="bprd_sec">Proposals Not Followed Up (&gt;14 Days)</div>
                        <div class="bprd_panel">
                            <table class="bprd_table">
                                <thead><tr>
                                    <th>Client</th>
                                    <th>Reference</th>
                                    <th>Rep</th>
                                    <th class="tr">Amount</th>
                                    <th class="tc">Days Stale</th>
                                </tr></thead>
                                <tbody>
                                    <t t-foreach="state.data.tables.stale_proposals" t-as="p" t-key="p.ref">
                                        <tr>
                                            <td class="bold" t-esc="p.partner"/>
                                            <td class="muted" t-esc="p.ref"/>
                                            <td t-esc="p.rep"/>
                                            <td class="tr bold" t-esc="fmt(p.amount)"/>
                                            <td class="tc">
                                                <span t-att-class="'bprd_pill ' + (p.age_days > 30 ? 'alert' : 'warn')"
                                                      t-esc="p.age_days + 'd'"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </t>

                    <!-- BPSI Signals -->
                    <div class="bprd_sec">BPSI Intelligence Signals</div>
                    <div class="bprd_signals_grid">
                        <t t-foreach="state.data.signals" t-as="sig" t-key="sig.code + sig_index">
                            <div class="bprd_signal_card">
                                <div class="bprd_signal_top">
                                    <div class="bprd_signal_badge" t-att-style="'background:' + sig.color" t-esc="sig.code"/>
                                    <div class="bprd_signal_head">
                                        <div class="bprd_signal_name" t-esc="sig.name"/>
                                    </div>
                                </div>
                                <div class="bprd_signal_body">
                                    <div class="bprd_signal_desc" t-esc="sig.desc"/>
                                    <t t-if="sig.nums.length">
                                        <div class="bprd_signal_nums">
                                            <t t-foreach="sig.nums" t-as="n" t-key="n.label">
                                                <div class="bprd_signal_num">
                                                    <span class="bprd_signal_num_label" t-esc="n.label"/>
                                                    <span class="bprd_signal_num_val" t-esc="n.value"/>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                                <div class="bprd_signal_footer">
                                    <span class="bprd_signal_perspective"
                                          t-att-style="'background:' + sig.perspective_color"
                                          t-esc="sig.perspective"/>
                                    <div class="bprd_signal_action" t-esc="sig.action"/>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div class="bprd_signals_note">Signals are computed from live Odoo data. Thresholds are calibrated for SME context.</div>

                    <div class="bprd_footer">Sales Manager — Restricted · Blackpaw Innovations</div>
                </div>
            </t>

            <t t-else="">
                <div class="bprd_empty">No data available.</div>
            </t>
        </div>
    </div>
</t>

</templates>
