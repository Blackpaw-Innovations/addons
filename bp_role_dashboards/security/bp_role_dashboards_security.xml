<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ── Dashboard access groups ────────────────────────────────────────── -->
        <!-- These groups appear in Settings > Users & Companies > Groups          -->
        <!-- The admin user automatically gets Dashboard Manager via user_ids.     -->

        <record id="group_bp_dashboards_user" model="res.groups">
            <field name="name">Blackpaw / Dashboard User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_bp_dashboards_manager" model="res.groups">
            <field name="name">Blackpaw / Dashboard Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_bp_dashboards_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
