                                                    <a href="{{ ctx['base_url'] }}/barber/booking" 
                                                       style="display: inline-block; padding: 15px 30px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px; font-size: 16px;">
                                                        📅 Book New Appointment
                                                    </a>
                                                </div>
                                                
                                                <p style="color: #666; font-size: 11px; margin-top: 30px;">
                                                    Thank you for choosing {{ object.company_id.name }}, and we hope to see you again soon!
                                                </p>
                                            </div>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </table>
</div>
        </field>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>