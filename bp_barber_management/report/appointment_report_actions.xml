<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action for Appointment Visit Summary -->
    <record id="action_report_bp_appointment_visit" model="ir.actions.report">
        <field name="name">Visit Summary</field>
        <field name="model">bp.barber.appointment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bp_barber_management.report_appointment_visit</field>
        <field name="report_file">bp_barber_management.report_appointment_visit</field>
        <field name="paperformat_id" ref="bp_barber_management.paperformat_barber_visit"/>
        <field name="print_report_name">'Visit_%s' % (object.name or '')</field>
        <field name="binding_model_id" ref="model_bp_barber_appointment"/>
        <field name="binding_type">report</field>
    </record>
</odoo>