<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Consumable Usage Tree View -->
    <record id="view_bp_consumable_usage_tree" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.tree</field>
        <field name="model">bp.barber.consumable.usage</field>
        <field name="arch" type="xml">
            <tree string="Consumable Usage" decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="date"/>
                <field name="barber_id"/>
                <field name="origin_type"/>
                <field name="appointment_id" optional="show"/>
                <field name="pos_order_id" optional="show"/>
                <field name="total_products"/>
                <field name="total_lines"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <!-- Consumable Usage Form View -->
    <record id="view_bp_consumable_usage_form" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.form</field>
        <field name="model">bp.barber.consumable.usage</field>
        <field name="arch" type="xml">
            <form string="Consumable Usage">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" 
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="barber_id"/>
                            <field name="origin_type"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="appointment_id" invisible="origin_type != 'appointment'"/>
                            <field name="pos_order_id" invisible="origin_type != 'pos'"/>
                            <field name="total_products"/>
                            <field name="total_lines"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Usage Lines" name="lines">
                            <field name="line_ids" readonly="state == 'done'">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="qty"/>
                                    <field name="uom_id"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Consumable Usage Search View -->
    <record id="view_bp_consumable_usage_search" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.search</field>
        <field name="model">bp.barber.consumable.usage</field>
        <field name="arch" type="xml">
            <search string="Search Usage Records">
                <field name="name" string="Usage"/>
                <field name="barber_id" string="Barber"/>
                <field name="appointment_id" string="Appointment"/>
                <field name="pos_order_id" string="POS Order"/>
                <separator/>
                <filter string="Draft" name="filter_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter string="Appointments" name="filter_appointments" domain="[('origin_type', '=', 'appointment')]"/>
                <filter string="POS Orders" name="filter_pos" domain="[('origin_type', '=', 'pos')]"/>
                <separator/>
                <filter string="Today" name="filter_today" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00')), ('date', '&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Week" name="filter_week" domain="[('date', '&gt;=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter string="This Month" name="filter_month" domain="[('date', '&gt;=', context_today().strftime('%Y-%m-01 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Barber" name="group_barber" context="{'group_by': 'barber_id'}"/>
                    <filter string="Origin Type" name="group_origin" context="{'group_by': 'origin_type'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:day'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Consumable Usage Action -->
    <record id="action_bp_consumable_usage" model="ir.actions.act_window">
        <field name="name">Consumable Usage</field>
        <field name="res_model">bp.barber.consumable.usage</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{
            'search_default_filter_done': 1,
            'search_default_filter_week': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No consumable usage records yet!
            </p>
            <p>
                Usage records are automatically created when appointments are 
                completed or POS orders are paid. They track which consumable 
                products were used by each barber.
            </p>
        </field>
    </record>

    <!-- Usage Lines Tree View (for reporting) -->
    <record id="view_bp_consumable_usage_line_tree" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.line.tree</field>
        <field name="model">bp.barber.consumable.usage.line</field>
        <field name="arch" type="xml">
            <tree string="Usage Lines">
                <field name="date"/>
                <field name="barber_id"/>
                <field name="product_id"/>
                <field name="qty" sum="Total Quantity"/>
                <field name="uom_id"/>
                <field name="usage_id"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <!-- Usage Lines Pivot View -->
    <record id="view_bp_consumable_usage_line_pivot" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.line.pivot</field>
        <field name="model">bp.barber.consumable.usage.line</field>
        <field name="arch" type="xml">
            <pivot string="Usage Analysis">
                <field name="date" type="row" interval="month"/>
                <field name="barber_id" type="row"/>
                <field name="product_id" type="col"/>
                <field name="qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Usage Lines Graph View -->
    <record id="view_bp_consumable_usage_line_graph" model="ir.ui.view">
        <field name="name">bp.barber.consumable.usage.line.graph</field>
        <field name="model">bp.barber.consumable.usage.line</field>
        <field name="arch" type="xml">
            <graph string="Usage Trends" type="line">
                <field name="date" interval="week"/>
                <field name="qty" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Usage Lines Action -->
    <record id="action_bp_consumable_usage_lines" model="ir.actions.act_window">
        <field name="name">Usage Lines Analysis</field>
        <field name="res_model">bp.barber.consumable.usage.line</field>
        <field name="view_mode">tree,pivot,graph</field>
        <field name="context">{
            'search_default_group_barber': 1,
            'search_default_group_product': 1
        }</field>
    </record>
</odoo>