<odoo>
    <record id="view_pos_config_invoice_payment_form" model="ir.ui.view">
        <field name="name">pos.config.form.invoice.payment</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='optical_enabled']/following-sibling::div[hasclass('content-group')]" position="inside">
                <div class="row mt16">
                    <label string="Allow Invoice Payments" for="allow_invoice_payments" class="col-lg-4 o_light_label"/>
                    <field name="allow_invoice_payments"/>
                </div>
                <div class="row mt8" invisible="not allow_invoice_payments">
                    <label string="Allow Partial Payments" for="allow_partial_invoice_payments" class="col-lg-4 o_light_label"/>
                    <field name="allow_partial_invoice_payments"/>
                </div>
                <div class="row mt8" invisible="not allow_invoice_payments">
                    <label string="Default Payment Mode" for="default_invoice_payment_mode" class="col-lg-4 o_light_label"/>
                    <field name="default_invoice_payment_mode"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
