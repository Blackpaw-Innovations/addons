<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend res.partner form view with optical fields and smart button -->
        <record id="view_partner_form_optical" model="ir.ui.view">
            <field name="name">res.partner.form.optical</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <!-- Add smart button for Optical Tests -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_optical_tests"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-eye">
                        <field name="x_test_count" widget="statinfo" string="Tests"/>
                    </button>
                    <button name="action_open_insurances"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shield">
                        <field name="x_insurance_count" widget="statinfo" string="Insurance"/>
                    </button>
                </xpath>

                <!-- Add Optical Information tab in notebook -->
                <xpath expr="//notebook" position="inside">
                    <page string="Optical Information" name="optical_info">
                        <group>
                            <group string="Clinical Snapshot">
                                <field name="is_optical_patient"/>
                                <field name="date_of_birth"/>
                                <field name="x_last_test_date" readonly="1"/>
                                <field name="x_test_count" readonly="1"/>
                                <field name="x_last_optometrist_id" readonly="1"/>
                                <field name="x_active_prescription" readonly="1"/>
                                <field name="x_prescription_valid_until" readonly="1"/>
                                <field name="x_follow_up_next_date" readonly="1"/>
                            </group>
                        </group>
                        <group string="Optical Notes">
                            <field name="x_optical_notes" nolabel="1" placeholder="Enter clinical notes about this patient..."/>
                        </group>
                    </page>
                    <page string="Insurance" name="insurance_info">
                        <group>
                            <button name="%(action_optical_patient_insurance)d" 
                                    string="Add Insurance" 
                                    type="action" 
                                    class="btn-primary"
                                    context="{'default_patient_id': active_id}"/>
                        </group>
                        <field name="insurance_ids" nolabel="1" context="{'default_patient_id': active_id}">
                            <tree limit="5" create="0" edit="0" delete="0">
                                <field name="name"/>
                                <field name="insurance_company_id"/>
                                <field name="date"/>
                                <field name="expiry_date"/>
                                <field name="active"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <!-- Search view extension for res.partner with Optical Patients filter -->
        <record id="view_partner_search_optical" model="ir.ui.view">
            <field name="name">res.partner.search.optical</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <!-- Add is_optical_patient to search fields so it can be used in filters -->
                <xpath expr="//field[@name='name']" position="after">
                    <field name="is_optical_patient" invisible="1"/>
                </xpath>

                <!-- Add Optical Patients filter -->
                <xpath expr="//filter[@name='inactive']" position="after">
                    <separator/>
                    <!-- Filter commented out due to 'Unsearchable field' error during installation, 
                         even though the field is stored and indexed. 
                         The field is added to search view above, so custom filters can be created. -->
                    <!-- <filter string="Optical Patients" 
                            name="optical_patients" 
                            domain="[('is_optical_patient', '=', True)]"/> -->
                </xpath>
                
                <!-- Add optical-specific group-by options -->
                <xpath expr="//group[@name='group_by']" position="inside">
                    <separator/>
                    <filter string="Last Optometrist" 
                            name="group_last_optometrist" 
                            context="{'group_by': 'x_last_optometrist_id'}"/>
                    <filter string="Last Test Date" 
                            name="group_last_test_date" 
                            context="{'group_by': 'x_last_test_date'}"/>
                </xpath>
            </field>
        </record>

