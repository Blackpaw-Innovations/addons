<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_bp_optical_solution" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.bp.optical.solution</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Optical" name="bp_optical_solution" data-string="BP Optical">
                    <block title="Point of Sale">
                        <setting help="Enable the optical POS flows (BP_Optical_solution).">
                            <field name="enable_optical_pos"/>
                        </setting>
                        <setting help="Enable POS Pay Invoice features alongside optical POS.">
                            <field name="enable_pos_pay_invoice"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
