<odoo>
    <record id="view_move_form_pos_invoice_payment" model="ir.ui.view">
        <field name="name">account.move.form.pos.invoice.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="%(point_of_sale.action_pos_pos_form)d"
                    type="action"
                    class="oe_stat_button"
                    icon="fa-money"
                    invisible="move_type != 'out_invoice'"
                >
                    <field name="pos_payment_total" widget="statinfo" string="POS Payments"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="POS Payments" invisible="move_type != 'out_invoice'">
                    <field name="bp_pos_payment_ids" readonly="1" nolabel="1">
                        <tree>
                            <field name="name" string="POS Order"/>
                            <field name="date_order"/>
                            <field name="invoice_payment_amount"/>
                            <field name="invoice_payment_mode"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
