<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Patient Insurance -->
    <record id="view_optical_patient_insurance_tree" model="ir.ui.view">
        <field name="name">optical.patient.insurance.tree</field>
        <field name="model">optical.patient.insurance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="insurance_company_id"/>
                <field name="date"/>
                <field name="expiry_date"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Patient Insurance -->
    <record id="view_optical_patient_insurance_form" model="ir.ui.view">
        <field name="name">optical.patient.insurance.form</field>
        <field name="model">optical.patient.insurance</field>
        <field name="arch" type="xml">
            <form string="Patient Insurance">
                <sheet>
                    <group>
                        <group>
                            <field name="patient_id" readonly="1"/>
                            <field name="insurance_company_id"/>
                            <field name="name"/>
                            <field name="invoice_number"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="expiry_date"/>
                            <field name="patient_company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="coverage_details" placeholder="Enter coverage details..."/>
                    </group>
                    <group>
                        <field name="document_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <group>
                        <field name="note" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Patient Insurance -->
    <record id="action_optical_patient_insurance" model="ir.actions.act_window">
        <field name="name">Add Insurance</field>
        <field name="res_model">optical.patient.insurance</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
