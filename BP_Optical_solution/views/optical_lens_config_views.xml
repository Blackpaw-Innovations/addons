                        <field name="note" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_optical_coating" model="ir.actions.act_window">
        <field name="name">Coatings</field>
        <field name="res_model">optical.coating</field>
        <field name="view_mode">tree,form</field>
    </record>

