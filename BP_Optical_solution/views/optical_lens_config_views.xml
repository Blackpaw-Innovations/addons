<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Lens Type Views -->
    <record id="view_optical_lens_type_tree" model="ir.ui.view">
        <field name="name">optical.lens.type.tree</field>
        <field name="model">optical.lens.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_optical_lens_type_form" model="ir.ui.view">
        <field name="name">optical.lens.type.form</field>
        <field name="model">optical.lens.type</field>
        <field name="arch" type="xml">
            <form string="Lens Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Additional notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_optical_lens_type" model="ir.actions.act_window">
        <field name="name">Lens Types</field>
        <field name="res_model">optical.lens.type</field>
        <field name="view_mode">tree,form</field>
    </record>

