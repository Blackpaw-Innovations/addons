    <!-- Menu Structure -->
    <menuitem id="menu_optical_lens" 
              name="Lens" 
              parent="menu_optical_configuration" 
              sequence="30"
              groups="BP_Optical_solution.group_optical_admin"/>

    <menuitem id="menu_optical_lens_type" 
              name="Lens Types" 
              parent="menu_optical_lens" 
              action="action_optical_lens_type" 
              sequence="10"/>

    <menuitem id="menu_optical_coating" 
              name="Coatings" 
              parent="menu_optical_lens" 
