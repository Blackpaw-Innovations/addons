<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View for Optical Patient -->
    <record id="view_optical_patient_kanban" model="ir.ui.view">
        <field name="name">optical.patient.kanban</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="phone"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="date_of_birth"/>
                <field name="branch_id"/>
                <field name="x_last_test_date"/>
                <field name="has_insurance"/>
                <field name="test_count"/>
                <field name="x_insurance_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click" style="padding: 16px;">
                            <!-- Heading Section -->
                            <div class="o_kanban_record_top" style="margin-bottom: 12px; display: flex; justify-content: space-between; align-items: flex-start;">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title" style="font-size: 16px; font-weight: 600; line-height: 1.5;">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="o_kanban_record_top_right">
                                    <span t-if="record.has_insurance.raw_value" 
                                          class="badge badge-success" 
                                          style="font-size: 11px; font-weight: 500; padding: 4px 8px;"
                                          title="Has Insurance">Insurance</span>
                                </div>
                            </div>
                            
                            <!-- Body Section -->
                            <div class="o_kanban_record_body" style="margin-bottom: 12px;">
                                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                                    <i class="fa fa-phone" style="font-size: 12px; color: #6c757d; width: 14px;" title="Phone"/>
                                    <span style="font-size: 14px; font-weight: 400;"><field name="phone"/></span>
                                </div>
                                <div t-if="record.mobile.raw_value" style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                                    <i class="fa fa-mobile" style="font-size: 12px; color: #6c757d; width: 14px;" title="Mobile"/>
                                    <span style="font-size: 14px; font-weight: 400;"><field name="mobile"/></span>
                                </div>
                                <div t-if="record.email.raw_value" style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                                    <i class="fa fa-envelope" style="font-size: 12px; color: #6c757d; width: 14px;" title="Email"/>
                                    <span style="font-size: 14px; font-weight: 400;"><field name="email"/></span>
                                </div>
                                <div t-if="record.date_of_birth.raw_value" style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                                    <i class="fa fa-birthday-cake" style="font-size: 12px; color: #6c757d; width: 14px;" title="Date of Birth"/>
                                    <span style="font-size: 14px; font-weight: 400;"><field name="date_of_birth"/></span>
                                </div>
                            </div>
                            
                            <!-- Footer Section -->
                            <div class="o_kanban_record_bottom" style="display: flex; justify-content: space-between; align-items: center; padding-top: 8px; border-top: 1px solid #e9ecef;">
                                <div class="oe_kanban_bottom_left">
                                    <field name="branch_id" widget="many2one_avatar"/>
                                </div>
                                <div class="oe_kanban_bottom_right" style="display: flex; gap: 8px;">
                                    <span t-if="record.test_count.raw_value" 
                                          class="badge badge-pill" 
                                          style="font-size: 11px; font-weight: 500; padding: 4px 8px; display: inline-flex; align-items: center; gap: 4px;"
                                          title="Tests">
                                        <i class="fa fa-eye" style="font-size: 11px;"/>
                                        <field name="test_count"/>
                                    </span>
                                    <span t-if="record.x_insurance_count.raw_value" 
                                          class="badge badge-pill" 
                                          style="font-size: 11px; font-weight: 500; padding: 4px 8px; display: inline-flex; align-items: center; gap: 4px;"
                                          title="Insurance">
                                        <i class="fa fa-shield" style="font-size: 11px;"/>
                                        <field name="x_insurance_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tree View for Optical Patient -->
    <record id="view_optical_patient_tree" model="ir.ui.view">
        <field name="name">optical.patient.tree</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <tree import="1">
                <field name="name"/>
                <field name="phone"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="date_of_birth"/>
                <field name="branch_id"/>
                <field name="x_last_test_date"/>
            </tree>
        </field>
    </record>

    <!-- Form View for Optical Patient -->
    <record id="view_optical_patient_form" model="ir.ui.view">
        <field name="name">optical.patient.form</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_optical_tests" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-eye"
                                invisible="test_count == 0">
                            <field name="test_count" widget="statinfo" string="Tests"/>
                        </button>
                        <button name="action_open_insurances" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-shield"
                                invisible="x_insurance_count == 0">
                            <field name="x_insurance_count" widget="statinfo" string="Insurance"/>
                        </button>
                        <button name="action_open_meetings" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-calendar"
                                invisible="meeting_count == 0">
                            <field name="meeting_count" widget="statinfo" string="Meetings"/>
                        </button>
                        <button name="action_open_sales" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-shopping-cart"
                                invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo" string="Sales"/>
                        </button>
                        <button name="action_open_purchases" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-truck"
                                invisible="purchase_order_count == 0">
                            <field name="purchase_order_count" widget="statinfo" string="Purchases"/>
                        </button>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Patient Name"/>
                        </h1>
                    </div>
                    
                    <field name="partner_id" invisible="1"/>

                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="branch_id"/>
                            <field name="has_insurance" widget="boolean_toggle"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Optical Information" name="optical_info">
                            <group>
                                <group string="Clinical Snapshot">
                                    <field name="x_last_test_date" readonly="1"/>
                                    <field name="x_test_count" readonly="1"/>
                                    <field name="x_last_optometrist_id" readonly="1"/>
                                    <field name="x_active_prescription" readonly="1"/>
                                    <field name="x_prescription_valid_until" readonly="1"/>
                                    <field name="x_follow_up_next_date" readonly="1"/>
                                </group>
                            </group>
                            <group string="Optical Notes">
                                <field name="x_optical_notes" nolabel="1" placeholder="Enter clinical notes about this patient..."/>
                            </group>
                        </page>
                        
                        <page string="Insurance" name="insurance_info" invisible="not has_insurance">
                            <group>
                                <button name="%(action_optical_patient_insurance)d" 
                                        string="Add Insurance" 
                                        type="action" 
                                        class="btn-primary"
                                        context="{'default_patient_id': partner_id}"/>
                            </group>
                            <field name="insurance_ids" nolabel="1" context="{'default_patient_id': partner_id}">
                                <tree limit="5" create="0" edit="0" delete="0">
                                    <field name="name"/>
                                    <field name="insurance_company_id"/>
                                    <field name="date"/>
                                    <field name="expiry_date"/>
                                    <field name="active"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View for Optical Patient -->
    <record id="view_optical_patient_search" model="ir.ui.view">
        <field name="name">optical.patient.search</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="mobile"/>
                <field name="email"/>
                <field name="branch_id"/>
                
                <!-- Filters -->
                <filter string="Has Insurance" name="filter_has_insurance" domain="[('has_insurance', '=', True)]"/>
                <filter string="No Insurance" name="filter_no_insurance" domain="[('has_insurance', '=', False)]"/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]" context="{'active_test': False}"/>
                <separator/>
                <filter string="Today" name="filter_today" domain="[('timeline_period', '=', 'today')]" icon="fa-calendar"/>
                <filter string="This Week" name="filter_week" domain="[('timeline_period', '=', 'week')]" icon="fa-calendar"/>
                <filter string="This Month" name="filter_month" domain="[('timeline_period', '=', 'month')]" icon="fa-calendar"/>
                <filter string="This Year" name="filter_year" domain="[('timeline_period', '=', 'year')]" icon="fa-calendar"/>
                
                <!-- Search Panel -->
                <searchpanel>
                    <!-- Branch Filter -->
                    <field name="branch_id" icon="fa-building" select="multi" enable_counters="1"/>
                    
                    <!-- Insurance Company Filter -->
                    <field name="insurance_company_ids" string="Insurance Company" icon="fa-shield" select="multi" enable_counters="1"/>
                </searchpanel>
                
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Insurance Status" name="group_insurance" context="{'group_by': 'has_insurance'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_optical_patient_graph" model="ir.ui.view">
        <field name="name">optical.patient.graph</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <graph string="Patient Analysis" type="bar">
                <field name="branch_id"/>
                <field name="has_insurance"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_optical_patient_pivot" model="ir.ui.view">
        <field name="name">optical.patient.pivot</field>
        <field name="model">optical.patient</field>
        <field name="arch" type="xml">
            <pivot string="Patient Analysis">
                <field name="branch_id" type="row"/>
                <field name="create_date" interval="month" type="col"/>
                <field name="has_insurance" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action for Optical Patient -->
    <record id="action_optical_patients_new" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">optical.patient</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new patient
            </p>
            <p>
                Add patient information including contact details and optical history.
            </p>
        </field>
    </record>

    <!-- Reporting Action -->
    <record id="action_optical_patient_reporting" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">optical.patient</field>
        <field name="view_mode">pivot,graph</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No data to display
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_optical_patients_new"
              name="Patients"
              parent="menu_bp_optical_root"
              action="action_optical_patients_new"
              sequence="20"/>

    <!-- Reporting Menu Item -->
    <menuitem id="menu_optical_patient_reporting"
              name="Patients"
              parent="menu_optical_reporting"
              action="action_optical_patient_reporting"
              sequence="20"/>
</odoo>
