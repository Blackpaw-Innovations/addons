<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="optical_stage_test_room" model="optical.prescription.stage">
            <field name="name">Test Room</field>
            <field name="sequence">10</field>
        </record>
        <record id="optical_stage_fitting" model="optical.prescription.stage">
            <field name="name">Fitting</field>
            <field name="sequence">20</field>
        </record>
        <record id="optical_stage_ready" model="optical.prescription.stage">
            <field name="name">Ready For collection</field>
            <field name="sequence">30</field>
        </record>
        <record id="optical_stage_completed" model="optical.prescription.stage">
            <field name="name">Completed</field>
            <field name="sequence">40</field>
            <field name="is_final" eval="True"/>
        </record>
    </data>
</odoo>
