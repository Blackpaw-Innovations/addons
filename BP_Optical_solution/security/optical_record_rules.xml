<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Record Rules -->
        <record id="rule_optical_branch_access" model="ir.rule">
            <field name="name">Optical Branch Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_branch"/>
            <field name="domain_force">['|', '|', ('manager_id', '=', user.id), ('user_ids', 'in', user.id), ('optician_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_user'))]"/>
        </record>

        <record id="rule_optical_test_branch_access" model="ir.rule">
            <field name="name">Optical Test Branch Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_test"/>
            <field name="domain_force">['|', '|', ('branch_id.manager_id', '=', user.id), ('branch_id.user_ids', 'in', user.id), ('branch_id.optician_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_user'))]"/>
        </record>

        <record id="rule_optical_patient_branch_access" model="ir.rule">
            <field name="name">Optical Patient Branch Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_patient"/>
            <field name="domain_force">['|', '|', ('branch_id.manager_id', '=', user.id), ('branch_id.user_ids', 'in', user.id), ('branch_id.optician_ids.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_user'))]"/>
        </record>

        <!-- Admin Rules (Full Access) -->
        <record id="rule_optical_branch_admin_access" model="ir.rule">
            <field name="name">Optical Branch Admin Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_branch"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_admin'))]"/>
        </record>

        <record id="rule_optical_test_admin_access" model="ir.rule">
            <field name="name">Optical Test Admin Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_test"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_admin'))]"/>
        </record>

        <record id="rule_optical_patient_admin_access" model="ir.rule">
            <field name="name">Optical Patient Admin Access</field>
            <field name="model_id" ref="BP_Optical_solution.model_optical_patient"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('BP_Optical_solution.group_optical_admin'))]"/>
        </record>
    </data>
</odoo>
