<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="ir_cron_mwanzo_staff_commission" model="ir.cron">
        <field name="name">Mwanzo Staff Commission - Daily</field>
        <field name="model_id" ref="bp_mwanzo_marketplace.model_mwanzo_staff_commission_ledger"/>
        <field name="state">code</field>
        <field name="code">model._cron_compute_staff_commissions()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall">False</field>
        <field name="active">True</field>
        <field name="cron_name">mwanzo_staff_commission</field>
        <field name="nextcall" eval="(DateTime.now() + relativedelta(hours=23, minutes=59)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>
</odoo>
