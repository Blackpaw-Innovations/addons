<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view inheritance for product.template -->
    <record id="stock_minimum_product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.stock.minimum</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Add minimum stock fields in the General Information tab -->
            <xpath expr="//group[@name='group_general']//field[@name='uom_id']" position="after">
                <field name="minimum_qty"/>
                <field name="below_minimum" readonly="1"/>
            </xpath>
            
            <!-- Add refresh button in the header -->
            <xpath expr="//form/header" position="inside">
                <button name="action_recompute_below_minimum" 
                        type="object" 
                        string="Refresh Below Minimum"
                        groups="product.group_product_manager"/>
            </xpath>
        </field>
    </record>

    <!-- Search view inheritance for product.template -->
    <record id="stock_minimum_product_template_search_inherit" model="ir.ui.view">
        <field name="name">product.template.search.inherit.stock.minimum</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter name="below_minimum" 
                        string="Below Minimum" 
                        domain="[('below_minimum', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <!-- Tree view inheritance for product.template -->
    <record id="stock_minimum_product_template_tree_inherit" model="ir.ui.view">
        <field name="name">product.template.tree.inherit.stock.minimum</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.view_stock_product_template_tree"/>
        <field name="arch" type="xml">
            <!-- Add decoration for below minimum products -->
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-danger">below_minimum == True</attribute>
            </xpath>
            <!-- Add minimum_qty and below_minimum columns after qty_available (On Hand) -->
            <xpath expr="//field[@name='qty_available']" position="after">
                <field name="minimum_qty" string="Min Qty"/>
                <field name="below_minimum" widget="boolean" string="Below Min"/>
            </xpath>
        </field>
    </record>
</odoo>