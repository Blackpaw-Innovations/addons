<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled action automatically updates the below_minimum flag for all products every 10 minutes -->
        <record id="stock_minimum_cron_recompute" model="ir.cron">
            <field name="name">Recompute Below Minimum</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">model.cron_recompute_below_minimum()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>